{
  "name": "airplain",
  "main": "./index.js",
  "version": "0.3.4",
  "scripts": {
    "start": "expo start",
    "android": "npm run generate:android-resources && expo run:android",
    "build": "npm run generate:android-resources && cd android && gradlew app:assembleRelease",
    "generate:android-resources": "node scripts/generate-android-resources.js",
    "test": "jest",
    "test:android": "npm run generate:android-resources && node -e \"const { spawnSync } = require('child_process'); const isWin = process.platform === 'win32'; const cmd = isWin ? 'gradlew.bat' : './gradlew'; const result = spawnSync(cmd, ['app:testDebugUnitTest'], { cwd: 'android', stdio: 'inherit', shell: isWin }); process.exit(result.status ?? 1);\"",
    "check-updates": "expo install --check",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "prettier:check": "npx prettier --list-different \"**/*.{ts,tsx}\"",
    "prettier:fix": "npx prettier --write \"**/*.{ts,tsx}\""
  },
  "jest": {
    "coverageDirectory": "./__reports__/coverage",
    "coverageReporters": [
      "clover",
      "json",
      "lcov",
      [
        "text",
        {
          "skipFull": true
        }
      ]
    ],
    "moduleNameMapper": {
      "constants/(palettes|themes|translations)[.]json": "<rootDir>/tests/__mocks__/$1.json",
      "^csv-parse/lib/sync$": "<rootDir>/node_modules/csv-parse/lib/sync.js"
    },
    "preset": "jest-expo",
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?|expo(nent)?|@expo(nent)?/.*|expo-modules-core/.*|expo-application/.*|expo-sqlite/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@unimodules/.*|unimodules|sentry-expo|native-base|react-native-svg|react-native-reanimated|react-native-worklets|react-native-picasso|i18n-js|make-plural)/)"
    ],
    "reporters": [
      "default",
      [
        "jest-junit",
        {
          "outputDirectory": "./__reports__/junit"
        }
      ]
    ],
    "setupFiles": [
      "./node_modules/react-native-gesture-handler/jestSetup.js",
      "./tests/jestSetup.js"
    ],
    "transform": {
      "\\.(sql|csv)$": "<rootDir>/tests/helpers/asset-transformer.js"
    }
  },
  "overrides": {
    "fast-xml-parser": "^5.3.4",
    "uuid": "^14.0.0",
    "joi": "^18.2.1"
  },
  "dependencies": {
    "@bwip-js/react-native": "^4.11.2",
    "@dr.pogodin/react-native-fs": "^2.39.2",
    "@expo/vector-icons": "^15.0.3",
    "@react-native-community/datetimepicker": "^8.4.4",
    "@react-native-community/netinfo": "11.4.1",
    "@react-navigation/material-top-tabs": "^7.4.11",
    "@react-navigation/native": "^7.1.8",
    "@shopify/react-native-skia": "^2.2.12",
    "bcbp": "^6.0.2",
    "buffer": "^6.0.3",
    "csv-parse": "^5.6.0",
    "expo": "~54.0.35",
    "expo-application": "~7.0.8",
    "expo-asset": "~12.0.12",
    "expo-brightness": "~14.0.8",
    "expo-build-properties": "~1.0.10",
    "expo-camera": "~17.0.10",
    "expo-constants": "^18.0.12",
    "expo-dev-client": "~6.0.21",
    "expo-document-picker": "~14.0.8",
    "expo-file-system": "~19.0.23",
    "expo-font": "~14.0.12",
    "expo-image": "~3.0.11",
    "expo-image-manipulator": "~14.0.8",
    "expo-image-picker": "~17.0.11",
    "expo-linking": "~8.0.12",
    "expo-localization": "~17.0.9",
    "expo-network": "~8.0.8",
    "expo-notifications": "~0.32.17",
    "expo-router": "~6.0.24",
    "expo-sharing": "~14.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-sqlite": "~16.0.10",
    "expo-status-bar": "~3.0.9",
    "expo-web-browser": "~15.0.11",
    "fflate": "^0.8.3",
    "i18n-js": "^4.5.3",
    "luxon": "^3.5.0",
    "mitt": "^3.0.1",
    "react": "19.1.0",
    "react-dom": "^19.1.0",
    "react-native": "0.81.5",
    "react-native-element-dropdown": "^2.12.4",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-pager-view": "^6.9.1",
    "react-native-picasso": "^1.1.12",
    "react-native-reanimated": "~4.1.1",
    "react-native-reorderable-list": "^0.17.0",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "^15.12.1",
    "react-native-tab-view": "^4.3.1",
    "react-native-view-shot": "~4.0.3",
    "react-native-web": "^0.21.2",
    "react-native-worklets": "0.5.1"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@react-native-community/cli": "^20.2.0",
    "@testing-library/react-native": "^13.3.3",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/jest": "^29.5.14",
    "@types/luxon": "^3.7.2",
    "@types/react": "~19.1.10",
    "jest": "^29.2.1",
    "jest-expo": "~54.0.17",
    "jest-junit": "^17.0.0",
    "oxlint": "^1.72.0",
    "prettier": "^3.9.4",
    "typescript": "~5.9.2"
  },
  "private": true
}
